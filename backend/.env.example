# Backend environment variables — copy to .env and fill in values

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=fake_news_detector

# JWT secret for admin authentication
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Google Fact Check Explorer API key
FACT_CHECK_API_KEY=your-google-api-key-here

# API host (used by browser extension)
API_HOST=http://localhost:8000

# spaCy model name
SPACY_MODEL=en_core_web_sm
